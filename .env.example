# Cainty CMS Configuration

# Application
APP_NAME="Cainty"
APP_URL="https://yourdomain.com"
APP_ENV=production
APP_DEBUG=false
APP_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING

# Database (sqlite or mysql)
DB_DRIVER=sqlite
DB_PATH=storage/cainty.db
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=cainty
# DB_USER=root
# DB_PASS=

# Theme
THEME=default

# Auth
AUTH_METHOD=local
# AUTH_METHOD=alexiuz_sso
# ALEXIUZ_AUTH_HUB=https://alexiuz.com

# Oomph Credits (managed hosting AI billing)
OOMPH_ENABLED=false
# OOMPH_SERVICE_NAME=cainty

# Alexiuz SSO (managed hosting)
# ALEXIUZ_SSO_CLIENT_ID=
# ALEXIUZ_SSO_CLIENT_SECRET=

# LLM API Keys (enter the ones you have)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# Image Generation (optional)
# GENEROR_API_KEY=
# GENEROR_API_URL=https://generor.com/api/v1

# Google TTS (optional, for TTS plugin)
# GOOGLE_TTS_API_KEY=

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=storage/uploads
